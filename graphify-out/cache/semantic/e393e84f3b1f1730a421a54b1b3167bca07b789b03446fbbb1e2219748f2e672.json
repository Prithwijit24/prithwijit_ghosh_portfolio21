{"nodes": [{"id": "specs_2026_06_21_portfolio_redesign_design", "label": "Portfolio Redesign Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_css_svg_3d_only", "label": "CSS/SVG 3D Only (No WebGL)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "rationale": "Keeps bundle small and works on any device a hiring manager might use. Real depth via perspective, transform-style preserve-3d, translateZ, layered parallax, and animated SVG.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_modular_split", "label": "Modular Split Architecture (Approach A)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "rationale": "Each file has one clear purpose and stays under ~200 lines, so it can be read and edited in isolation. Sections, scenes, primitives, decorations, and data each get focused files.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_no_new_deps", "label": "No New Runtime Dependencies", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "rationale": "No new runtime dependencies; dev deps unchanged; bundle size stays small. Color-mix and other CSS features are browser-native.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_single_scroll", "label": "Single-Scroll Experience", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "rationale": "Single-scroll keeps a hiring manager engaged for longer. No routing or multi-page app; the rainbow-spring narrative flows top to bottom.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_reduced_motion", "label": "prefers-reduced-motion Compliance", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "rationale": "Every animation respects prefers-reduced-motion: reduce \u2014 scenes become static, transitions become instant fades. Decorative 3D scenes are aria-hidden.", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_color_blend_system", "label": "Color-Blend Transition System", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_rainbow_spring_theme", "label": "Rainbow-Spring Theme", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_sectionshell", "label": "SectionShell Component Pattern", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_2026_06_21_portfolio_redesign_design_about_toggle", "label": "About Toggle in Hero", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-06-21-portfolio-redesign-design.md", "source_location": null, "source_url": null, "captured_at": n